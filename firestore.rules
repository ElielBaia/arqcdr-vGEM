rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function existing() {
      return resource.data;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidPBIMProject(data) {
      return data.keys().hasAll(['userId', 'projectData', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 5 // + name
        && data.userId is string 
        && data.userId.size() > 0
        && data.userId.size() <= 128
        && data.name is string
        && data.name.size() <= 256
        && data.projectData is map;
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;

      allow create: if isSignedIn() 
        && isValidId(projectId)
        && isValidPBIMProject(incoming())
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'projectData', 'updatedAt'])
        && incoming().updatedAt == request.time;
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
